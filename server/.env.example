PORT=3000
MONGO_URI=mongodb://127.0.0.1:27017/mails_system
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10
NODE_ENV=development

# SMTP settings for OTP email delivery
# Gmail example:
# - SMTP_HOST=smtp.gmail.com
# - SMTP_PORT=465
# - SMTP_SECURE=true
# - SMTP_USER=your-gmail-address
# - SMTP_PASS=your-16-char-app-password-without-spaces
# - SMTP_FROM=the-same-gmail-address
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password-no-spaces
SMTP_FROM=your-email@gmail.com

# Encryption key for organization-level SMTP credentials stored in DB.
# Use a long random value in production.
MAIL_CONFIG_ENCRYPTION_KEY=replace-with-a-long-random-secret-for-smtp-config
